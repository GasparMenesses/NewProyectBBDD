@startuml
actor Usuario as User

package "Capa de Presentación (Frontend)" {
  [Navegador Web / Cliente HTTP] as Browser
  folder "Templates (HTML/CSS)" {
    [dashboard.html]
    [login.html]
    [register.html]
  }
}

package "Capa Lógica (Backend Flask)" {
  [Main.py (Entrypoint)] as Main
  
  package "Módulos (Blueprints)" {
    [Auth (Autenticación)] as Auth
    [Inscripciones (Transaccional)] as Inscripciones
    [ABM (Gestión Entidades)] as ABM
    [Reportes (Analíticas)] as Reportes
  }

  [database.py\n(Gestión de Conexiones)] as DBConn
}

database "MySQL / deportes_ucu" as DB

User -> Browser : interactúa con la UI
Browser -> Main : Peticiones HTTP
Main -> Auth : delega /login, /register
Main -> Inscripciones : delega /api/inscripciones
Main -> ABM : delega altas/bajas/modificaciones
Main -> Reportes : delega /api/reportes

Auth --> DBConn : solicitar conexión
Inscripciones --> DBConn : solicitar conexión
ABM --> DBConn : solicitar conexión
Reportes --> DBConn : solicitar conexión

DBConn -> DB : establecer conexión a MySQL
DB --> DBConn : OK
Auth -> DB : consultas sobre tabla 'usuarios'
Inscripciones -> DB : transacciones (SELECT FOR UPDATE)
ABM -> DB : INSERT/UPDATE entidades
Reportes -> DB : SELECTs de solo lectura

Main --> Browser : Renderiza Plantilla o JSON
Browser --> User : Actualiza Vista

note bottom of Main
  El backend ahora cumple con **Principios SOLID** y Clean Code.
  `Main.py` actúa únicamente como orquestador.
  Toda la lógica de negocio y presentación está desacoplada
  en módulos (Blueprints) y plantillas (Templates) independientes.
end note

@enduml